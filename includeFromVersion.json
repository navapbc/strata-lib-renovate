// -*- mode: jsonc -*-
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Include current version in update messages",
  "packageRules": [
    {
      "packagePatterns": ["*"],
      // For the "from ..." part, there is no prettyCurrentVersion to match
      // prettyNewVersion in "to ...", so make our own
      //
      // For the "to ..." part match upstream:
      // https://docs.renovatebot.com/configuration-options/#commitmessageextra
      "commitMessageExtra": "from {{replace '^v*' 'v' currentVersion}} to {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}{{prettyNewMajor}}{{else}}{{#if isSingleVersion}}{{prettyNewVersion}}{{else}}{{#if newValue}}{{{newValue}}}{{else}}{{{newDigestShort}}}{{/if}}{{/if}}{{/if}}{{/if}}"
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "commitMessageExtra": "from {{{currentDigestShort}}} to {{{newDigestShort}}}"
    }
  ]
}
