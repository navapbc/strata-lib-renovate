// -*- mode: jsonc -*-
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Separate out changes that are for the template itself and do not impact instances, using the legacy `template-only-*` convention",
  "packageRules": [
    {
      "matchFileNames": ["**/template-only*{/,}**"],
      "commitMessagePrefix": "template-only:",
      "additionalBranchPrefix": "template-only-"
    },
  ]
}
