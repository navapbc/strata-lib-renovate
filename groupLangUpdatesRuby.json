// -*- mode: jsonc -*-
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Group updates to the Ruby language",
  "extends": [
    "customManagers:dockerfileVersions"
  ],
  "packageRules": [
    {
      "groupName": "Ruby language",
      "groupSlug": "ruby-lang",
      "matchManagers": [
        "bundler",
        "dockerfile",
        "custom.regex",
        "ruby-version"
      ],
      "matchDatasources": [
        "docker",
        "rubygems",
        "ruby-version"
      ],
      "matchDepNames": [
        "ruby",
        "registry.docker.com/library/ruby"
      ],
      "commitMessageTopic": "Ruby language"
    }
  ]
}
